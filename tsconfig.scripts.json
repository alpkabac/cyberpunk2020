{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": ".scripts-out",
    "rootDir": "scripts",
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": ["scripts/**/*.ts"]
}
