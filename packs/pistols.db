{"_id":"0sXQ6uFPRR8Mv6AC","name":"Colt .45 \"Peacemaker\"","type":"weapon","img":"systems/cyberpunk2020/img/weapon-icon.svg","data":{"flavor":"The gun \"that won the West\", the .45 was the most common US sidearm throughout the 1800's. A single action weapon, it must be cocked before firing, although later models had a flattened hammer allowing the gun to be fired by \"fanning\" the hammer.","notes":"","cost":"","weight":"1","equipped":true,"source":"Cyberpunk 2020","weaponType":"Pistol","accuracy":"","concealability":"ConcealJacket","availability":"Rare","ammoType":".45","damage":"2d6+2","rangeDamages":{"pointBlank":"","close":"","medium":"","far":"","short":"","extreme":""},"ap":false,"shotsLeft":"6","shots":"6","rof":"1","reliability":"VeryReliable","range":"50","attackType":"","attackSkill":"Handgun","name":"Common"},"effects":[],"folder":null,"sort":0,"permission":{"default":0,"VTdezBIy0FQgKDge":3},"flags":{"exportSource":{"world":"cyberpunk_2020","system":"cyberpunk2020","coreVersion":"0.7.9","systemVersion":"0.2.6"}}}
