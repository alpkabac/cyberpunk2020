{"_id":"RtszmKt0YuYTHTpM","name":"M-16A2","type":"weapon","img":"systems/cyberpunk2020/img/weapon-icon.svg","data":{"flavor":"Standard US military rifle since the 1960's, the M-16 has high accuracy and a staggering ROF. A built in \"tumble\" effect compensates for the light 5.56 round. Earlier M-16 models were cantankerous and unrealiable in the extreme, with an accuracy of 1, not 2. The AR-15 and the AR-180 are civilian models used by police and home defense.","notes":"","cost":"","weight":"2","equipped":true,"source":"Cyberpunk 2020","weaponType":"Rifle","accuracy":"2","concealability":"ConcealNoHide","availability":"Common","ammoType":"5.56","damage":"4d6","rangeDamages":{"pointBlank":"","close":"","medium":"","far":"","short":"","extreme":""},"ap":false,"shotsLeft":"30","shots":"30","rof":"25","reliability":"Unreliable","range":"400","attackType":"Auto","attackSkill":"Rifle","name":"Common"},"effects":[],"folder":null,"sort":0,"permission":{"default":0,"VTdezBIy0FQgKDge":3},"flags":{"exportSource":{"world":"cyberpunk_2020","system":"cyberpunk2020","coreVersion":"0.7.9","systemVersion":"0.2.6"}}}
