{"_id":"PcZ4s5FJIPPCwYIs","name":"Bushmaster","type":"weapon","img":"systems/cyberpunk2020/img/weapon-icon.svg","data":{"flavor":"A bull pup configured SMG designed to be fired one handed. The Bushmaster uses the M-1 6A 1 clip, making it technically closer to an assault rifle than a submachinegun.","notes":"","cost":"","weight":"1","equipped":true,"source":"Cyberpunk 2020","weaponType":"SMG","accuracy":"","concealability":"ConcealNoHide","availability":"Rare","ammoType":"5.56","damage":"4d6","rangeDamages":{"pointBlank":"","close":"","medium":"","far":"","short":"","extreme":""},"ap":false,"shotsLeft":"30","shots":"30","rof":"20","reliability":"Standard","range":"200","attackType":"Auto","attackSkill":"Submachinegun","name":"Common"},"effects":[],"folder":null,"sort":0,"permission":{"default":0,"VTdezBIy0FQgKDge":3},"flags":{"exportSource":{"world":"cyberpunk_2020","system":"cyberpunk2020","coreVersion":"0.7.9","systemVersion":"0.2.6"}}}
{"_id":"RhzsWiWK6KJwZ17m","name":"Ingram MAC 10","type":"weapon","img":"systems/cyberpunk2020/img/weapon-icon.svg","data":{"flavor":"A very small SMG used by covert units and terrorists. It can be easily silenced. However, its very large ammo size makes it very difficult to control when on full auto.","notes":"","cost":"","weight":"1","equipped":true,"source":"Cyberpunk 2020","weaponType":"SMG","accuracy":"-1","concealability":"ConcealJacket","availability":"Common","ammoType":".45","damage":"2d6+2","rangeDamages":{"pointBlank":"","close":"","medium":"","far":"","short":"","extreme":""},"ap":false,"shotsLeft":"30","shots":"30","rof":"5","reliability":"Unreliable","range":"200","attackType":"Auto","attackSkill":"Submachinegun","name":"Common"},"effects":[],"folder":null,"sort":0,"permission":{"default":0,"VTdezBIy0FQgKDge":3},"flags":{"exportSource":{"world":"cyberpunk_2020","system":"cyberpunk2020","coreVersion":"0.7.9","systemVersion":"0.2.6"}}}
{"_id":"Wmj87qSWJR72f30f","name":"Arasaka Minami 10","type":"weapon","img":"systems/cyberpunk2020/img/weapon-icon.svg","data":{"flavor":"The standard Arasaka Security weapon, found worldwide. A good, all round weapon.","notes":"","cost":"500","weight":"3","equipped":true,"source":"Cyberpunk 2020","weaponType":"SMG","accuracy":"","concealability":"ConcealJacket","availability":"Excellent","ammoType":"10mm","damage":"2D6+3","rangeDamages":{"pointBlank":"","close":"","medium":"","far":"","short":"","extreme":""},"ap":false,"shotsLeft":"40","shots":"40","rof":"20","reliability":"VeryReliable","range":"200","attackType":"Auto","attackSkill":"Submachinegun","name":"Common"},"effects":[],"folder":null,"sort":0,"permission":{"default":0,"VTdezBIy0FQgKDge":3},"flags":{"exportSource":{"world":"cyberpunk_2020","system":"cyberpunk2020","coreVersion":"0.7.9","systemVersion":"0.2.6"}}}
{"_id":"Y5Y4fkvE0YWeS5M8","name":"H&K MPK-11","type":"weapon","img":"systems/cyberpunk2020/img/weapon-icon.svg","data":{"flavor":"Possibly the most used Solo's gun in existence, the MPK-11 can be modified into four different designs, including a bullpup configuration, standard SMG, an assault carbine, and a grenade launcher mount.","notes":"","cost":"700","weight":"3","equipped":true,"source":"Cyberpunk 2020","weaponType":"SMG","accuracy":"","concealability":"ConcealLongcoat","availability":"Common","ammoType":"12mm","damage":"4D6+1","rangeDamages":{"pointBlank":"","close":"","medium":"","far":"","short":"","extreme":""},"ap":false,"shotsLeft":"30","shots":"30","rof":"20","reliability":"Standard","range":"200","attackType":"Auto","attackSkill":"Submachinegun","name":"Common"},"effects":[],"folder":null,"sort":0,"permission":{"default":0,"VTdezBIy0FQgKDge":3},"flags":{"exportSource":{"world":"cyberpunk_2020","system":"cyberpunk2020","coreVersion":"0.7.9","systemVersion":"0.2.6"}}}
{"_id":"ZPRv9RxGpq4xZfaV","name":"H&K MP5","type":"weapon","img":"systems/cyberpunk2020/img/weapon-icon.svg","data":{"flavor":"Two examples of the H&K family of interchangeable SMGs, both share parts and design similarities. The MP5K is a very small version of the MP5SD3, which has a built in silencer.","notes":"","cost":"","weight":"1","equipped":true,"source":"Cyberpunk 2020","weaponType":"SMG","accuracy":"1","concealability":"ConcealLongcoat","availability":"Common","ammoType":"9mm","damage":"2d6+1","rangeDamages":{"pointBlank":"","close":"","medium":"","far":"","short":"","extreme":""},"ap":false,"shotsLeft":"30","shots":"30","rof":"20","reliability":"Standard","range":"200","attackType":"Auto","attackSkill":"Submachinegun","name":"Common"},"effects":[],"folder":null,"sort":0,"permission":{"default":0,"VTdezBIy0FQgKDge":3},"flags":{"exportSource":{"world":"cyberpunk_2020","system":"cyberpunk2020","coreVersion":"0.7.9","systemVersion":"0.2.6"}}}
{"_id":"cqpagxyo0Srhnso7","name":"Vz61 \"Skorpion\"","type":"weapon","img":"systems/cyberpunk2020/img/weapon-icon.svg","data":{"flavor":"A standard military sidearm for the Soviet Bloc, the Skorpion is the world's smallest military SMG. It's small ammunition size gives it excellent controllability. It is easily silenced and can be carried in a shoulder holster.","notes":"","cost":"","weight":"1","equipped":true,"source":"Cyberpunk 2020","weaponType":"SMG","accuracy":"2","concealability":"ConcealJacket","availability":"Poor","ammoType":".25","damage":"1d6","rangeDamages":{"pointBlank":"","close":"","medium":"","far":"","short":"","extreme":""},"ap":false,"shotsLeft":"20","shots":"20","rof":"25","reliability":"VeryReliable","range":"150","attackType":"Auto","attackSkill":"Submachinegun","name":"Common"},"effects":[],"folder":null,"sort":0,"permission":{"default":0,"VTdezBIy0FQgKDge":3},"flags":{"exportSource":{"world":"cyberpunk_2020","system":"cyberpunk2020","coreVersion":"0.7.9","systemVersion":"0.2.6"}}}
