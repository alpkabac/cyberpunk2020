{"_id":"83ZoOnKvQOrwhX06","name":"Thompson M1928","type":"weapon","img":"systems/cyberpunk2020/img/weapon-icon.svg","data":{"flavor":"Standard US military SMG during WWII, the Thompson is rugged, reliable and easy to use. The M1928 version, of gangster fame, was less reliable (UR), but could carry a 50 round drum magazine.","notes":"","cost":"","weight":"1","equipped":true,"source":"Cyberpunk 2020","weaponType":"SMG","accuracy":"2","concealability":"ConcealNoHide","availability":"Common","ammoType":".45","damage":"2d6+2","rangeDamages":{"pointBlank":"","close":"","medium":"","far":"","short":"","extreme":""},"ap":false,"shotsLeft":"50","shots":"50","rof":"20","reliability":"Unreliable","range":"200","attackType":"Auto","attackSkill":"Submachinegun","name":"Common"},"effects":[],"folder":null,"sort":0,"permission":{"default":0,"VTdezBIy0FQgKDge":3},"flags":{"exportSource":{"world":"cyberpunk_2020","system":"cyberpunk2020","coreVersion":"0.7.9","systemVersion":"0.2.6"}}}
