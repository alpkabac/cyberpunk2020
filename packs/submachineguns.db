{"_id":"0hplCzyqq3XKBRtW","name":"Uzi Miniauto 9","type":"weapon","img":"systems/cyberpunk2020/img/weapon-icon.svg","data":{"flavor":"Uzi's entry into the 21st century, all plastic, with a rotary electric clip and adjustable trigger. The choice for many security Solos.","notes":"","cost":"475","weight":"3","equipped":true,"source":"Cyberpunk 2020","weaponType":"SMG","accuracy":"1","concealability":"ConcealJacket","availability":"Excellent","ammoType":"9mm","damage":"2D6+1","rangeDamages":{"pointBlank":"","close":"","medium":"","far":"","short":"","extreme":""},"ap":false,"shotsLeft":"30","shots":"30","rof":"35","reliability":"VeryReliable","range":"150","attackType":"Auto","attackSkill":"Submachinegun","name":"Common"},"effects":[],"folder":null,"sort":0,"permission":{"default":0,"VTdezBIy0FQgKDge":3},"flags":{"exportSource":{"world":"cyberpunk_2020","system":"cyberpunk2020","coreVersion":"0.7.9","systemVersion":"0.2.6"}}}
